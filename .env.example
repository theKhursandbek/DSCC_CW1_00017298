# ============================================================
# Django Application — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Django
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost

# PostgreSQL (used by Docker Compose)
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=newspass

# Database URL (used by Django via environs)
DATABASE_URL=postgres://newsuser:newspass@db:5432/newsdb
